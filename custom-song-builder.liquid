{{ 'custom-song-builder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign brand_color = section.settings.brand_color | default: '#465fff'
  assign heading_text = section.settings.heading | default: 'Create Your Custom Song'
  assign subheading_text = section.settings.subheading
-%}

<div
  class="csb-wrapper"
  id="csb-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-backend-url="{{ section.settings.backend_url | default: 'YOUR_BACKEND_URL' }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-product-handle="{{ product.handle }}"
  data-rush-variant-id="{{ section.settings.rush_order_product.selected_or_first_available_variant.id }}"
  style="--csb-brand: {{ brand_color }};"
>
  <div class="csb-card">
    
    <!-- Bot Protection: Honeypot -->
    <div class="csb-hp-field" style="display:none; visibility:hidden; position:absolute; top:-9999px; left:-9999px;" aria-hidden="true">
      <label for="csb-website-hp">Leave this field blank</label>
      <input type="text" id="csb-website-hp" name="website_url" data-csb-field="hp_website" tabindex="-1" autocomplete="off">
    </div>
    {%- if heading_text != blank or subheading_text != blank -%}
      <div class="csb-card-top-header">
        {%- if heading_text != blank -%}<h1 class="csb-main-title">{{ heading_text }}</h1>{%- endif -%}
        {%- if subheading_text != blank -%}<p class="csb-main-subtitle">{{ subheading_text }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <!-- Progress Bar -->
    <div class="csb-progress-wrap" data-csb-progress-wrap>
      <div class="csb-progress-row">
        <span data-csb-step-label>Step 1 of 10</span>
        <span data-csb-percent-label>0% Complete</span>
      </div>
      <div class="csb-progress-track">
        <div class="csb-progress-fill" data-csb-progress-fill style="width: 0%;"></div>
      </div>
    </div>

    <div class="csb-steps-container">

      <!-- STEP 1: Occasion -->
      <section class="csb-step" data-csb-step="1">
        <div class="csb-step-head">
          <h2>{{ section.settings.step1_title | default: "What's the occasion?" }}</h2>
          <p>{{ section.settings.step1_subtitle | default: "Select the event or reason for your custom song." }}</p>
        </div>
        <div class="csb-pill-group csb-center" data-csb-occasions>
          <div class="csb-loading-text">Loading occasions...</div>
        </div>
        <div class="csb-narrow csb-gap-top" data-csb-occasion-other-wrap hidden>
          <label class="csb-label">{{ section.settings.step1_other_label | default: "Please specify your occasion" }}</label>
          <input type="text" class="csb-input" placeholder="{{ section.settings.step1_other_placeholder | default: "e.g. Housewarming, New Job, Just Because..." }}" data-csb-field="customOccasion">
        </div>
      </section>

      <!-- STEP 2: For Whom -->
      <section class="csb-step" data-csb-step="2" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step2_title | default: "Who is this song for?" }}</h2>
          <p>{{ section.settings.step2_subtitle | default: "Enter the name(s) that should be in the song." }}</p>
        </div>
        <div class="csb-narrow">
          <div data-csb-recipients-wrap class="csb-recipients-wrap">
            <!-- Dynamically populated by JS -->
          </div>
          <button type="button" class="csb-btn-outline csb-gap-top" data-csb-add-recipient>
            + Add another person
          </button>
        </div>
      </section>

      <!-- STEP 3: Creation Method & Story -->
      <section class="csb-step" data-csb-step="3" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step3_title | default: "How would you like to provide your song?" }}</h2>
        </div>
        <div class="csb-medium">
          <div class="csb-method-grid">
            <button type="button" class="csb-method-card" data-csb-method="write_for_us">
              <span class="csb-method-title">{{ section.settings.step3_method1_title | default: "We'll write the lyrics" }}</span>
              <span class="csb-method-desc">{{ section.settings.step3_method1_desc | default: "Tell us your story and we'll turn it into song lyrics." }}</span>
            </button>
            <button type="button" class="csb-method-card" data-csb-method="own_lyrics">
              <span class="csb-method-title">{{ section.settings.step3_method2_title | default: "I have my own lyrics" }}</span>
              <span class="csb-method-desc">{{ section.settings.step3_method2_desc | default: "Paste your lyrics and we'll turn them into a professional song." }}</span>
            </button>
          </div>

          <!-- write_for_us panel -->
          <div data-csb-panel="write_for_us" hidden>
            <label class="csb-label">{{ section.settings.step3_story_label | default: "What makes this song special?" }}</label>
            <p class="csb-hint">{{ section.settings.step3_story_hint | default: "Include how you met, memories, nicknames, hobbies, character traits..." }}</p>
            <textarea class="csb-textarea" rows="6" placeholder="{{ section.settings.step3_story_placeholder | default: "We met at a coffee shop in 2018. She loves hiking and reading..." }}" data-csb-field="storyText"></textarea>

            <div class="csb-lyrics-lang-row csb-gap-top">
              <div class="csb-lyrics-lang-field">
                <label class="csb-label" for="csb-lyrics-lang-{{ section.id }}">Lyrics Language</label>
                <select class="csb-select" id="csb-lyrics-lang-{{ section.id }}" data-csb-field="lyricsLanguage">
                  <!-- Options populated by JS -->
                </select>
              </div>
              <button type="button" class="csb-btn-primary" data-csb-generate-lyrics>
                <span class="csb-spinner" data-csb-lyrics-spinner hidden></span>
                <span data-csb-generate-lyrics-label>✨ Generate AI Lyrics</span>
              </button>
            </div>
            <p class="csb-error-text" data-csb-lyrics-error hidden></p>

            <div data-csb-lyrics-variations hidden class="csb-gap-top">
              <label class="csb-label csb-success-text">✓ Lyrics generated! Choose your favorite:</label>
              <div class="csb-variations-grid" data-csb-variations-grid></div>

              <div class="csb-gap-top">
                <label class="csb-label">You can edit the selected lyrics below:</label>
                <textarea class="csb-textarea" rows="6" data-csb-field="lyrics"></textarea>
              </div>
              <div class="csb-center csb-gap-top">
                <button type="button" class="csb-btn-secondary" data-csb-generate-lyrics-again>
                  <span class="csb-spinner" data-csb-lyrics-spinner-2 hidden></span>
                  <span data-csb-regen-label>↻ Regenerate Lyrics</span>
                </button>
              </div>
            </div>
          </div>

          <!-- own_lyrics panel -->
          <div data-csb-panel="own_lyrics" hidden>
            <label class="csb-label">{{ section.settings.step3_own_lyrics_label | default: "Paste your lyrics below" }}</label>
            <textarea class="csb-textarea" rows="8" placeholder="Verse 1:&#10;Your lyrics here...&#10;&#10;Chorus:&#10;The chorus..." data-csb-field="lyrics"></textarea>
          </div>
        </div>
      </section>

      <!-- STEP 4: Lyrics Review -->
      <section class="csb-step" data-csb-step="4" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step4_title | default: "Review your lyrics" }}</h2>
          <p>{{ section.settings.step4_subtitle | default: "Make any final edits before we compose your song." }}</p>
        </div>
        <div class="csb-medium">
          <textarea class="csb-textarea" rows="10" data-csb-field="lyrics"></textarea>
          <p class="csb-hint">You can edit the lyrics directly above!</p>
        </div>
      </section>

      <!-- STEP 5: Email -->
      <section class="csb-step" data-csb-step="5" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step5_title | default: "Where should we send it?" }}</h2>
          <p>{{ section.settings.step5_subtitle | default: "Demo songs can be played instantly in the next step!" }}</p>
        </div>
        <div class="csb-narrow csb-gap-top-lg">
          <div class="csb-demo-lock-box" data-csb-lock-box>
            <div class="csb-demo-lock-icon" data-csb-lock-icon>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 1.5rem; height: 1.5rem;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path data-csb-lock-shackle d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <div class="csb-demo-lock-text">
              {% assign lock_text = section.settings.step5_lock_text | default: "Unlock Your Free Demo 🎶\nWe'll email your completed songs as soon as they're finished." %}
              {{ lock_text | newline_to_br }}
            </div>
          </div>

          <label class="csb-label csb-gap-top">Your Email Address</label>
          <input type="email" class="csb-input" placeholder="you@email.com" data-csb-field="email">
          
          <div class="csb-social-proof">
            <p>{{ section.settings.step5_social_proof1 | default: "4.9 / ⭐⭐⭐⭐⭐ - thousands of songs created" }}</p>
            <p>{{ section.settings.step5_social_proof2 | default: "No spam, no newsletter — just your song." }}</p>
          </div>

          <!-- Cloudflare Turnstile Widget -->
          <div class="csb-turnstile-wrap csb-gap-top">
            <div class="cf-turnstile" data-sitekey="{{ section.settings.turnstile_site_key | default: 'YOUR_TURNSTILE_SITEKEY' }}" data-callback="onTurnstileSuccess"></div>
          </div>
        </div>
      </section>

      <!-- STEP 6: Music Style -->
      <section class="csb-step" data-csb-step="6" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step6_title | default: "Choose your style" }}</h2>
          <p>{{ section.settings.step6_subtitle | default: "Pick the genre, voice, and mood for your song." }}</p>
        </div>
        <div data-csb-style-groups>
          <div class="csb-loading-text csb-center">Loading style options...</div>
        </div>
      </section>

      <!-- STEP 7: Generating Music -->
      <section class="csb-step" data-csb-step="7" hidden>
        <div class="csb-generating" data-csb-generating-ok>
          <div class="csb-spinner-lg"></div>
          <h2>Composing your melody...</h2>
          <p>We are generating two unique versions of your song. This usually takes 1-3 minutes, occasionally longer.</p>
          <div class="csb-progress-track csb-progress-track-wide">
            <div class="csb-progress-fill" data-csb-gen-progress-fill style="width: 0%;"></div>
          </div>
          <p class="csb-percent-text" data-csb-gen-progress-text>0%</p>
        </div>
        <div class="csb-generating" data-csb-generating-error hidden>
          <div class="csb-error-icon">❌</div>
          <h2>Generation Failed</h2>
          <p class="csb-error-text" data-csb-gen-error-text></p>
          <button type="button" class="csb-btn-secondary" data-csb-gen-back>Go Back &amp; Try Again</button>
        </div>
      </section>

      <!-- STEP 8: Listen to Demos -->
      <section class="csb-step" data-csb-step="8" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step7_title | default: "Listen to your songs" }}</h2>
          <p data-csb-tracks-count>We've generated 2 versions. Pick your favorite!</p>
        </div>
        <div class="csb-tracks-grid" data-csb-tracks-grid></div>
        <div class="csb-center csb-gap-top">
          <button type="button" class="csb-btn-secondary" data-csb-regen-songs>↻ Regenerate Songs</button>
        </div>
      </section>

      <!-- STEP 9: Choose Package -->
      <section class="csb-step" data-csb-step="9" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step8_title | default: "Choose Your Package" }}</h2>
        </div>
        <div class="csb-packages-grid" data-csb-packages-grid>
          <div class="csb-loading-text csb-center">Loading packages...</div>
        </div>
      </section>

      <!-- STEP 10: Confirm Order -->
      <section class="csb-step" data-csb-step="10" hidden>
        <div class="csb-step-head">
          <h2>{{ section.settings.step9_title | default: "Confirm your order" }}</h2>
          <p>{{ section.settings.step9_subtitle | default: "Review your choices and proceed to checkout." }}</p>
        </div>
        <div class="csb-summary-box">

          <h3>Order Summary</h3>
          <ul class="csb-summary-list" data-csb-summary-list></ul>

          <div class="csb-summary-song" data-csb-summary-song hidden>
            <p class="csb-summary-section-label">🎧 Your selected song</p>
            <div class="csb-summary-song-card">
              <div class="csb-summary-song-art" data-csb-summary-song-art></div>
              <div class="csb-summary-song-info">
                <p class="csb-summary-song-title" data-csb-summary-song-title></p>
                <div class="csb-summary-song-audio" data-csb-summary-song-audio></div>
              </div>
            </div>
          </div>

          <div class="csb-summary-package" data-csb-summary-package hidden>
            <p class="csb-summary-section-label">📦 Your selected package</p>
            <div class="csb-summary-package-card" data-csb-summary-package-card></div>
          </div>
          
          {%- if section.settings.rush_order_product != blank -%}
          <div class="csb-rush-order-box csb-gap-top">
            <label class="csb-checkbox-row csb-checkbox-rush">
              <input type="checkbox" data-csb-field="rushOrder">
              <div class="csb-rush-order-info">
                <span class="csb-rush-order-title">Rush My Order</span>
                <span class="csb-rush-order-text">{{ section.settings.rush_order_text | default: "Order delivered in 60 minutes" }}</span>
              </div>
              <span class="csb-rush-order-price" data-csb-rush-price>{{ section.settings.rush_order_product.price | money }}</span>
            </label>
          </div>
          {%- endif -%}

          <div class="csb-summary-total-row">
            <span class="csb-summary-total-label">Total Price</span>
            <span class="csb-summary-total-value" data-csb-total-price>—</span>
          </div>

          <div class="csb-gap-top-lg">
            <label class="csb-checkbox-row csb-align-start">
              <input type="checkbox" data-csb-field="agreeTerms">
              <span>
                I agree to the
                {%- if section.settings.terms_url != blank -%}
                  <a href="{{ section.settings.terms_url }}" target="_blank" rel="noopener noreferrer" class="csb-terms-link">terms and conditions</a>
                {%- else -%}
                  terms and conditions
                {%- endif -%}
                and understand that custom generated songs cannot be refunded.
              </span>
            </label>
          </div>
        </div>
      </section>

    </div>

    <!-- Purchased View -->
    <div class="csb-purchased-view" data-csb-purchased-view hidden>
      <div class="csb-purchased-icon">🎉</div>
      <h2 class="csb-main-title">Music Already Purchased</h2>
      <p class="csb-main-subtitle">You have already successfully purchased this custom song.</p>
    </div>

    <!-- Navigation -->
    <div class="csb-nav" data-csb-nav>
      <button type="button" class="csb-btn-back" data-csb-back>Back</button>
      <button type="button" class="csb-btn-next" data-csb-next>Next Step</button>
      <button type="button" class="csb-btn-checkout" data-csb-checkout hidden>
        <span class="csb-spinner" data-csb-checkout-spinner hidden></span>
        <span data-csb-checkout-label>Checkout &amp; Pay</span>
      </button>
    </div>

  </div>
</div>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script src="{{ 'custom-song-builder.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Song Builder",
  "settings": [
    {
      "type": "header",
      "content": "General Form Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create Your Custom Song"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Step 1: Occasion"
    },
    { "type": "text", "id": "step1_title", "label": "Title", "default": "What's the occasion?" },
    { "type": "text", "id": "step1_subtitle", "label": "Subtitle", "default": "Select the event or reason for your custom song." },
    { "type": "text", "id": "step1_other_label", "label": "Other Occasion Label", "default": "Please specify your occasion" },
    { "type": "text", "id": "step1_other_placeholder", "label": "Other Occasion Placeholder", "default": "e.g. Housewarming, New Job, Just Because..." },
    {
      "type": "header",
      "content": "Step 2: Who is this for"
    },
    { "type": "text", "id": "step2_title", "label": "Title", "default": "Who is this song for?" },
    { "type": "text", "id": "step2_subtitle", "label": "Subtitle", "default": "Enter the name(s) that should be in the song." },
    {
      "type": "header",
      "content": "Step 3: Creation Method"
    },
    { "type": "text", "id": "step3_title", "label": "Title", "default": "How would you like to provide your song?" },
    { "type": "text", "id": "step3_method1_title", "label": "Method 1 Title", "default": "We'll write the lyrics" },
    { "type": "text", "id": "step3_method1_desc", "label": "Method 1 Desc", "default": "Tell us your story and we'll turn it into song lyrics." },
    { "type": "text", "id": "step3_method2_title", "label": "Method 2 Title", "default": "I have my own lyrics" },
    { "type": "text", "id": "step3_method2_desc", "label": "Method 2 Desc", "default": "Paste your lyrics and we'll turn them into a professional song." },
    { "type": "text", "id": "step3_story_label", "label": "Story Field Label", "default": "What makes this song special?" },
    { "type": "text", "id": "step3_story_hint", "label": "Story Field Hint", "default": "Include how you met, memories, nicknames, hobbies, character traits..." },
    { "type": "text", "id": "step3_story_placeholder", "label": "Story Placeholder", "default": "We met at a coffee shop in 2018. She loves hiking and reading..." },
    { "type": "text", "id": "step3_own_lyrics_label", "label": "Own Lyrics Label", "default": "Paste your lyrics below" },
    {
      "type": "header",
      "content": "Step 4: Lyrics Review"
    },
    { "type": "text", "id": "step4_title", "label": "Title", "default": "Review your lyrics" },
    { "type": "text", "id": "step4_subtitle", "label": "Subtitle", "default": "Make any final edits before we compose your song." },
    {
      "type": "header",
      "content": "Step 5: Email"
    },
    { "type": "text", "id": "step5_title", "label": "Title", "default": "Where should we send it?" },
    { "type": "text", "id": "step5_subtitle", "label": "Subtitle", "default": "Demo songs can be played instantly in the next step!" },
    { "type": "textarea", "id": "step5_lock_text", "label": "Lock Box Text", "default": "Unlock Your Free Demo 🎶\nWe'll email your completed songs as soon as they're finished." },
    { "type": "text", "id": "step5_social_proof1", "label": "Social Proof Line 1", "default": "4.9 / ⭐⭐⭐⭐⭐ - thousands of songs created" },
    { "type": "text", "id": "step5_social_proof2", "label": "Social Proof Line 2", "default": "No spam, no newsletter — just your song." },
    {
      "type": "header",
      "content": "Step 6: Style"
    },
    { "type": "text", "id": "step6_title", "label": "Title", "default": "Choose your style" },
    { "type": "text", "id": "step6_subtitle", "label": "Subtitle", "default": "Pick the genre, voice, and mood for your song." },
    {
      "type": "header",
      "content": "Step 7: Listen"
    },
    { "type": "text", "id": "step7_title", "label": "Title", "default": "Listen to your songs" },
    {
      "type": "header",
      "content": "Step 8: Packages"
    },
    { "type": "text", "id": "step8_title", "label": "Title", "default": "Choose Your Package" },
    {
      "type": "header",
      "content": "Step 9: Confirm"
    },
    { "type": "text", "id": "step9_title", "label": "Title", "default": "Confirm your order" },
    { "type": "text", "id": "step9_subtitle", "label": "Subtitle", "default": "Review your choices and proceed to checkout." },
    { "type": "product", "id": "rush_order_product", "label": "Rush Order Product" },
    { "type": "text", "id": "rush_order_text", "label": "Rush Order Text", "default": "Order delivered in 60 minutes" },
    { "type": "url", "id": "terms_url", "label": "Terms URL" },
    {
      "type": "header",
      "content": "Configuration"
    },
    { "type": "color", "id": "brand_color", "label": "Brand / accent color", "default": "#465fff" },
    { "type": "text", "id": "backend_url", "label": "Backend base URL", "default": "YOUR_BACKEND_URL" },
    { "type": "text", "id": "turnstile_site_key", "label": "Turnstile Site Key", "default": "1x00000000000000000000AA" }
  ],
  "presets": [
    {
      "name": "Custom Song Builder"
    }
  ]
}
{% endschema %}
